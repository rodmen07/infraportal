# Admin pages (#/admin, #/crm/admin, #/search, #/crm/reports, #/observaboard, #/admin/health, #/admin/audit)
VITE_ADMIN_KEY=dev-admin
VITE_ADMIN_JWT=

# Auth service (OAuth + JWT)
VITE_AUTH_SERVICE_URL=http://localhost:8000

# Client portal
VITE_PROJECTS_API_BASE_URL=http://localhost:3015

# CRM services
VITE_CONTACTS_API_BASE_URL=http://localhost:3011
VITE_ACCOUNTS_API_BASE_URL=http://localhost:3010
VITE_OPPORTUNITIES_API_BASE_URL=http://localhost:3012
VITE_ACTIVITIES_API_BASE_URL=http://localhost:3013
VITE_AUTOMATION_API_BASE_URL=http://localhost:3014
VITE_INTEGRATIONS_API_BASE_URL=http://localhost:3016

# Audit service
VITE_AUDIT_API_BASE_URL=http://localhost:3017

# Event stream (SSE hub)
VITE_EVENT_STREAM_URL=http://localhost:8085

# Search service
VITE_SEARCH_API_BASE_URL=http://localhost:8083

# Reporting service
VITE_REPORTING_API_BASE_URL=http://localhost:8086

# Public lead intake endpoint (unauthenticated)
# POST receives either:
# - Consultation payload: { name, email, project_type, timeline, message }
# - Lead magnet payload with additional metadata fields
# This endpoint should be a public webhook or intake proxy.
# Do not point directly at contacts-service /api/v1/contacts because it requires JWT auth.
VITE_LEAD_INTAKE_URL=

# Optional scheduling link shown on the contact page (e.g. Calendly, Cal.com)
VITE_SCHEDULING_URL=

# Stripe Payment Links API bootstrap (used by scripts/setup-stripe-payment-links.mjs)
# Use a restricted secret key in test mode first, then switch to live.
STRIPE_SECRET_KEY=
STRIPE_SITE_URL=https://rodmen07.github.io/infraportal
STRIPE_THANK_YOU_URL=https://rodmen07.github.io/infraportal/#/checkout-thank-you
STRIPE_CURRENCY=usd
STRIPE_ARCH_REVIEW_UNIT_CENTS=12500
STRIPE_PROJECT_DEPOSIT_CENTS=50000
STRIPE_RETAINER_WEEKLY_CENTS=100000

# Observaboard (Django REST API)
VITE_OBSERVABOARD_URL=https://observaboard-rodmen07.fly.dev

# Spend tracking service
VITE_SPEND_API_BASE_URL=http://localhost:3020
